TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OPENROUTER_API_KEY=
# Prefer an explicit :free model. `openrouter/auto` often hits congested Venice routes and 429s.
OPENROUTER_MODEL=google/gemini-2.5-flash-lite:free
# Comma-separated fallbacks if the primary keeps returning 429 (optional).
OPENROUTER_MODEL_FALLBACK=
# Optional: repo URL for OpenRouter rankings (defaults to placeholder in code).
OPENROUTER_HTTP_REFERER=
# Optional: Pepper REST API request signature (if you have one). When unset, the bot parses listing HTML instead of /rest_api/v2.
PEPPER_API_SIGNATURE=
# Optional: override browser User-Agent for Pepper HTTP (HTML + REST).
PEPPER_USER_AGENT=
NOTIFIER=telegram
DRY_RUN=0
