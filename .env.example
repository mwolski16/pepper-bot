TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Manual runs + status pings: npm run telegram — then send /digest or /hunter from the TELEGRAM_CHAT_ID chat (long polling; keep the process running).
OPENROUTER_API_KEY=
# Optional: pin one :free model to try first. Leave empty to auto-pick from OpenRouter's /models list (largest context first). Do not use openrouter/* routers here.
OPENROUTER_MODEL=
# Optional: extra model ids to try after the pinned model (if any) and before the auto-ranked list.
OPENROUTER_MODEL_FALLBACK=
# Optional: repo URL for OpenRouter rankings (defaults to placeholder in code).
OPENROUTER_HTTP_REFERER=
# Optional: Pepper REST API request signature (if you have one). When unset, the bot parses listing HTML instead of /rest_api/v2.
PEPPER_API_SIGNATURE=
# Optional: override browser User-Agent for Pepper HTTP (HTML + REST).
PEPPER_USER_AGENT=
NOTIFIER=telegram
DRY_RUN=0
